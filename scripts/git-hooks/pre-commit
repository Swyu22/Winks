#!/usr/bin/env bash
# Winks pre-commit hook
# 注册方式：git config core.hooksPath scripts/git-hooks
# 行为：对仓库执行 npm run lint，lint 失败则阻止提交。
# 不要使用 --no-verify 绕过；请先修复 lint 错误。

set -e

if ! command -v npm >/dev/null 2>&1; then
  echo "[pre-commit] npm not found in PATH. Skipping lint." >&2
  exit 0
fi

# 仅在 staged 文件中包含 .js / .jsx 时跑 lint，节省时间。
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|cjs|mjs)$' || true)
if [ -z "$staged" ]; then
  exit 0
fi

echo "[pre-commit] Running: npm run lint"
npm run lint --silent
